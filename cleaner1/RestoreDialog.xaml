<Window x:Class="ModernFileCleaner.RestoreDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="System Restore Point" Height="320" Width="500"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        Topmost="True"
        Background="#FF1E1E1E">
    <Border CornerRadius="16" Background="#FF1E1E1E" BorderBrush="#FF333333" BorderThickness="1" Padding="28">
        <StackPanel>
            <!-- Shield Icon -->
            <Border CornerRadius="12" Background="#1A0078D4" Width="64" Height="64" HorizontalAlignment="Center" Margin="0,0,0,16">
                <TextBlock Text="🛡️" FontSize="32" HorizontalAlignment="Center" VerticalAlignment="Center"/>
            </Border>

            <TextBlock Text="Create a Restore Point?" FontSize="20" FontWeight="Bold" Foreground="White" HorizontalAlignment="Center" Margin="0,0,0,8"/>
            <TextBlock TextWrapping="Wrap" FontSize="13" Foreground="#FF999999" HorizontalAlignment="Center" TextAlignment="Center" Margin="0,0,0,20">
                System Sweep is about to make changes to your system. Creating a restore point lets you undo these changes if needed. This is strongly recommended before applying tweaks or cleaning system files.
            </TextBlock>

            <!-- Status -->
            <Border x:Name="StatusBox" CornerRadius="8" Background="#1AFFAA00" Padding="12" Margin="0,0,0,20" Visibility="Collapsed">
                <TextBlock x:Name="txtStatus" Text="" FontSize="13" Foreground="#FFCCAA00" HorizontalAlignment="Center"/>
            </Border>

            <!-- Buttons -->
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Button x:Name="btnSkip" Grid.Column="0" Content="⏭  Skip"
                        Background="#FF333333" Foreground="#FF999999"
                        FontSize="14" FontWeight="SemiBold"
                        Height="42" Margin="0,0,6,0"
                        BorderThickness="0"
                        Cursor="Hand"
                        Click="Skip_Click"/>
                <Button x:Name="btnCreate" Grid.Column="1" Content="🛡️  Create Restore Point"
                        Background="#FF0078D4" Foreground="White"
                        FontSize="14" FontWeight="Bold"
                        Height="42" Margin="6,0,0,0"
                        BorderThickness="0"
                        Cursor="Hand"
                        Click="Create_Click"/>
            </Grid>

            <TextBlock Text="This won't be shown again if you create a restore point"
                       FontSize="11" Foreground="#FF555555" HorizontalAlignment="Center" Margin="0,16,0,0"/>
        </StackPanel>
    </Border>
</Window>
