<Window x:Class="ModernFileCleaner.ActivationDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
        Title="Activate System Sweep" Height="450" Width="560"
        WindowStartupLocation="CenterScreen" ResizeMode="NoResize"
        Background="#FF1E1E1E" Topmost="True">
    <Border CornerRadius="16" Background="#FF1E1E1E" BorderBrush="#FF333333" BorderThickness="1" Padding="28" Margin="0">
        <StackPanel>
            <Border CornerRadius="12" Background="#FF0078D4" Width="64" Height="64" HorizontalAlignment="Center" Margin="0,0,0,16">
                <TextBlock Text="🔑" FontSize="32" HorizontalAlignment="Center" VerticalAlignment="Center"/>
            </Border>

            <TextBlock Text="Activate System Sweep" FontSize="22" FontWeight="Bold" Foreground="White" HorizontalAlignment="Center"/>
            <TextBlock TextWrapping="Wrap" FontSize="13" Foreground="#FF999999" HorizontalAlignment="Center" TextAlignment="Center" Margin="0,8,0,20">
                Enter your license key to unlock all features. You can also start a free trial.
            </TextBlock>

            <!-- Status -->
            <Border x:Name="StatusBox" CornerRadius="8" Background="#1A0078D4" Padding="12" Margin="0,0,0,16" Visibility="Visible">
                <TextBlock x:Name="txtStatus" Text="🔓 You are in trial mode" FontSize="13" Foreground="#FFCCCCCC" HorizontalAlignment="Center"/>
            </Border>

            <!-- License Key Input -->
            <TextBox x:Name="txtLicenseKey" FontSize="18" Height="44"
                     HorizontalAlignment="Stretch" Padding="12,0"
                     BorderBrush="#FF444444" BorderThickness="1"
                     Background="#FF111111" Foreground="White" CaretBrush="White"
                     Text="" Margin="0,0,0,6"/>
            <TextBlock Text="Paste your Keyzy.io license key here" FontSize="11" Foreground="#FF666666" Margin="0,0,0,16"/>

            <!-- Buttons -->
            <ui:Button x:Name="btnActivate" Content="🔑  Activate License" Appearance="Primary"
                       Width="240" Height="42" HorizontalAlignment="Center" Margin="0,0,0,12"
                       Click="Activate_Click"/>

            <ui:Button x:Name="btnTrial" Content="⏭  Continue in Trial Mode" Appearance="Secondary"
                       Width="220" Height="34" HorizontalAlignment="Center" Margin="0,0,0,4"
                       Click="Trial_Click"/>

            <TextBlock Text="Trial: 30 days full access" FontSize="11" Foreground="#FF555555" HorizontalAlignment="Center"/>
        </StackPanel>
    </Border>
</Window>
