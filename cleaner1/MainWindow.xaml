<ui:FluentWindow x:Class="ModernFileCleaner.MainWindow"
                  xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                  xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                  xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
                  xmlns:pages="clr-namespace:ModernFileCleaner.Pages"
                  Title="System Sweep"
                  Height="750"
                  Width="1100"
                  WindowStartupLocation="CenterScreen"
                  ExtendsContentIntoTitleBar="True"
                  WindowBackdropType="Mica">

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="220"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- Sidebar -->
        <Border Grid.Column="0" Background="#FF1E1E1E">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- App Logo -->
                <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="16,20,16,20">
                    <Border CornerRadius="8" Background="#FF0078D4" Width="32" Height="32" Margin="0,0,10,0">
                        <TextBlock Text="&#xE8B7;" FontFamily="/Wpf.Ui;Component/Resources/Font/#Segoe Fluent Icons"
                                   FontSize="16" Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <TextBlock Text="System Sweep" FontSize="16" FontWeight="SemiBold" Foreground="White" VerticalAlignment="Center"/>
                </StackPanel>

                <!-- Nav Items -->
                <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                    <StackPanel>
                        <RadioButton x:Name="navDashboard" Content="Dashboard" Tag="dashboard"
                                     Style="{StaticResource NavRadioStyle}" IsChecked="True"
                                     Margin="8,0,8,2"/>
                        <RadioButton x:Name="navClean" Content="Clean" Tag="clean"
                                     Style="{StaticResource NavRadioStyle}" Margin="8,0,8,2"/>
                        <RadioButton x:Name="navBrowser" Content="Browser Cache" Tag="browsers"
                                     Style="{StaticResource NavRadioStyle}" Margin="8,0,8,2"/>
                        <RadioButton x:Name="navDuplicates" Content="Duplicates" Tag="duplicates"
                                     Style="{StaticResource NavRadioStyle}" Margin="8,0,8,2"/>
                        <RadioButton x:Name="navStartup" Content="Startup" Tag="startup"
                                     Style="{StaticResource NavRadioStyle}" Margin="8,0,8,2"/>
                        <RadioButton x:Name="navTweaks" Content="⚡ Tweaks" Tag="tweaks"
                                     Style="{StaticResource NavRadioStyle}" Margin="8,0,8,2"/>
                        <TextBlock Text="TOOLS" Foreground="#FF666666" FontSize="11" FontWeight="Bold"
                                   Margin="16,16,16,8"/>
                        <RadioButton x:Name="navStats" Content="Statistics" Tag="stats"
                                     Style="{StaticResource NavRadioStyle}" Margin="8,0,8,2"/>
                        <RadioButton x:Name="navSettings" Content="Settings" Tag="settings"
                                     Style="{StaticResource NavRadioStyle}" Margin="8,0,8,2"/>
                        <RadioButton x:Name="navAbout" Content="About" Tag="about"
                                     Style="{StaticResource NavRadioStyle}" Margin="8,0,8,2"/>
                        <Border Height="1" Background="#FF333333" Margin="16,8"/>
                        <RadioButton x:Name="navLicense" Content="🔐 License" Tag="license"
                                     Style="{StaticResource NavRadioStyle}" Margin="8,0,8,2"/>
                    </StackPanel>
                </ScrollViewer>

                <!-- Theme Toggle Footer -->
                <Border Grid.Row="2" BorderBrush="#FF333333" BorderThickness="0,1,0,0" Padding="16,12">
                    <StackPanel>
                        <Button x:Name="btnTheme" Background="Transparent" BorderThickness="0"
                                Foreground="#FF888888" HorizontalAlignment="Left"
                                Click="btnTheme_Click">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock x:Name="txtThemeIcon" Text="&#xE706;"
                                           FontFamily="/Wpf.Ui;Component/Resources/Font/#Segoe Fluent Icons" FontSize="16" Margin="0,0,10,0"/>
                                <TextBlock x:Name="txtThemeLabel" Text="Dark Mode" FontSize="13"/>
                            </StackPanel>
                        </Button>
                    </StackPanel>
                </Border>
            </Grid>
        </Border>

        <!-- Content Area -->
        <Frame x:Name="NavFrame" Grid.Column="1" NavigationUIVisibility="Hidden"/>
    </Grid>
</ui:FluentWindow>
